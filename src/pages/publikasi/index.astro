---
import Layout from "../../layouts/Layout.astro";
import { sql } from "../../lib/db";

// Narik postingan yang statusnya PUBLISHED, sekalian gabungin ke tabel profil buat dapet nama penulisnya
const { rows: posts } = await sql`
  SELECT
    p.title,
    p.content,
    p.slug,
    p.updated_at,
    pr.full_name as author_name
  FROM posts p
  LEFT JOIN profiles pr ON p.user_id = pr.id
  WHERE p.status = 'published'
  ORDER BY p.updated_at DESC
`;

// Fungsi pembantu buat motong konten biar gak kepanjangan di kotak preview
const truncateText = (text: string | null, length = 120) => {
  if (!text) return "Tidak ada ringkasan...";
  return text.length > length ? text.substring(0, length) + "..." : text;
};

// Fungsi pembantu buat format tanggal ala Indonesia
const formatDate = (date: any) => {
  if (!date) return "";
  return new Date(date).toLocaleDateString("id-ID", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};
---

<Layout title="Publikasi | Literasi Brebesan">
  <main class="min-h-screen bg-slate-50 pt-24 pb-12">
    <div class="max-w-5xl mx-auto px-4">

      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight mb-4">
          Publikasi <span class="text-blue-600">Kanca</span>
        </h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Kumpulan tulisan, cerita, dan literasi dari kanca-kanca Brebesan. Baca, resapi, dan bagikan!
        </p>
      </div>

      {posts.length === 0 ? (
        <div class="bg-white p-12 rounded-3xl border border-slate-100 text-center shadow-sm">
          <div class="text-4xl mb-4">📝</div>
          <h2 class="text-xl font-bold text-slate-900 mb-2">Belum ada tulisan</h2>
          <p class="text-slate-500">Admin belum nge-publish tulisan apa-apa. Sabar yak, Nyet!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <article class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
              <div class="p-6 flex flex-col h-full">

                <div class="flex items-center justify-between text-xs font-semibold text-slate-400 mb-4 uppercase tracking-wider">
                  <span>{formatDate(post.updated_at)}</span>
                  <span class="text-blue-600 bg-blue-50 px-2 py-1 rounded-md">{post.author_name || "Anonim"}</span>
                </div>

                <h2 class="text-xl font-bold text-slate-900 mb-3 leading-snug line-clamp-2">
                  <a href={`/publikasi/${post.slug}`} class="hover:text-blue-600 transition-colors">
                    {post.title}
                  </a>
                </h2>

                <p class="text-slate-600 text-sm mb-6 flex-grow line-clamp-3">
                  {truncateText(post.content)}
                </p>

                <div class="mt-auto pt-4 border-t border-slate-50">
                  <a
                    href={`/publikasi/${post.slug}`}
                    class="inline-flex items-center text-sm font-bold text-blue-600 hover:text-blue-800 transition-colors"
                  >
                    Baca selengkapnya
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                  </a>
                </div>

              </div>
            </article>
          ))}
        </div>
      )}

    </div>
  </main>
</Layout>