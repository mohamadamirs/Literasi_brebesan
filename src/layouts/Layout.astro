---
import "../styles/global.css";
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string; // Memungkinkan kustomisasi class body dari layout turunan
}

// Menambahkan fallback title agar seragam
const {
  title,
  description = "Wadah literasi digital wong Brebes",
  bodyClass = "bg-slate-200 min-h-screen font-sans antialiased text-slate-900"
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title.includes('Literasi Brebesan') ? title : `${title} - Literasi Brebesan`}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link href="https://fonts.bunny.net/css?family=plus-jakarta-sans:400,500,600,700,800" rel="stylesheet" />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>