---
interface Props {
  post: {
    id: string;
    title: string;
    content?: string;
    status?: string;
    author?: string;
    created_at: Date;
  };
  isAdmin?: boolean;
}

const { post, isAdmin = false } = Astro.props;

// Format tanggal simpel
const date = new Date(post.created_at).toLocaleDateString('id-ID', {
  day: 'numeric',
  month: 'short',
});

// Warna Status
const statusColor =
  post.status === 'published' ? 'bg-green-100 text-green-700' :
  post.status === 'pending' ? 'bg-blue-600 text-white' : 'bg-slate-100 text-slate-500';
---

<div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm hover:border-blue-200 transition-all group">
  <div class="flex flex-col gap-2">

    <div class="flex items-center justify-between mb-1">
      <div class="flex items-center gap-2">
        {post.status && (
          <span class={`text-[8px] px-1.5 py-0.5 rounded font-bold uppercase tracking-tighter ${statusColor}`}>
            {post.status}
          </span>
        )}
        {post.author && (
          <span class="text-[9px] font-bold text-slate-400 uppercase truncate max-w-[80px]">
            {post.author}
          </span>
        )}
      </div>
      <span class="text-[9px] font-medium text-slate-300 uppercase">{date}</span>
    </div>

    <h3 class="text-sm font-bold text-slate-900 group-hover:text-blue-600 transition-colors leading-snug">
      {post.title}
    </h3>

    {post.content && (
      <p class="text-xs text-slate-500 line-clamp-2 leading-relaxed">
        {post.content}
      </p>
    )}

    <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-50">
      <a
        href={isAdmin ? `/admin/posts/${post.id}` : `/user/posts/edit/${post.id}`}
        class="text-[10px] font-bold text-blue-600 hover:underline uppercase tracking-widest"
      >
        Lihat Detail →
      </a>

      <div class="flex items-center gap-2">
         {/* Slot buat naruh tombol hapus atau ACC dari luar kalau perlu */}
         <slot name="actions" />
      </div>
    </div>

  </div>
</div>